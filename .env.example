# --- Labsis MVP-mock ---
# Copia este archivo a .env y ajusta los valores.

# Anthropic (usado por ia-mapper como fallback LLM para tramas no reconocidas)
ANTHROPIC_API_KEY=

# Si se pone "true", el ia-mapper NUNCA llama al LLM y usa sólo parsers deterministas.
# Útil para demos sin conectividad.
IA_FALLBACK_ONLY=false

# Identidad del equipo simulado (se propaga a FHIR.performer)
EQUIPO_ID=EQ-LAB-001
